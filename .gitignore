# Claude Code — réglages/notes propres à une machine ou une personne (jamais
# partagés), à distinguer de .claude/settings.json et .claude/skills|hooks|
# agents/ qui eux restent versionnés pour toute l'équipe.
.claude/settings.local.json
CLAUDE.local.md

# Roadmap — .roadmap/roadmap.json est la source de verite versionnee ;
# le .svg est regenere a la demande par le skill roadmap-keeper.
.roadmap/*.svg

# Bytecode Python (regenere par toute execution de docs/cadrage-ppt/*.py)
__pycache__/

# BMAD — sorties generees (planning/implementation artifacts), pas du
# contenu source ; _bmad/ (le moteur, ~138K) reste versionne a part.
_bmad-output/

# Images generees a la volee pour les cadres photo du deck (pptx-framed-image
# + nature_images) - regenerables via generate_deck.py, pas a committer.
docs/cadrage-ppt/_img/

# Fichier verrou PowerPoint (cree quand le .pptx est ouvert via COM, ex. le
# script de rendu pptx-verify) - artefact temporaire, jamais du contenu.
**/~$*.pptx

# Documents importes pour analyse (decks commerciaux internes OCTO avec
# references clients et tarifs) - ne jamais pousser sur le depot public ;
# seules les notes d'extraction redactees (*.md) sont versionnees.
docs/Import/*.pdf

# Superviseur/orchestrateur des agents - donnees machine generees par
# scan_transcripts.py/log_usage.py/log_run.py, jamais editees a la main.
# .claude/supervision/arbitrages.json reste VERSIONNE (decisions humaines).
.claude/supervision/state.json
.claude/supervision/usage.jsonl
.claude/supervision/diagnostic.json
.claude/orchestration/runs.jsonl
.claude/orchestration/routing-hints.json
