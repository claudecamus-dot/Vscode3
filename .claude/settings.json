{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash|PowerShell",
        "hooks": [
          {
            "type": "command",
            "command": "py \"${CLAUDE_PROJECT_DIR}/.claude/hooks/guard_destructive_git.py\"",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "py \"$CLAUDE_PROJECT_DIR/.claude/hooks/warn_verif_before_commit.py\"",
            "timeout": 10,
            "statusMessage": "Verif reelle avant commit (code applicatif)..."
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "py \"${CLAUDE_PROJECT_DIR}/.claude/hooks/remind_revue_increment.py\"",
            "timeout": 10,
            "statusMessage": "Rappel discipline revue-increment..."
          },
          {
            "type": "command",
            "command": "py \"${CLAUDE_PROJECT_DIR}/.claude/supervision/scan_transcripts.py\"",
            "timeout": 60,
            "statusMessage": "Supervision agents : scan incremental des transcripts..."
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "py \"${CLAUDE_PROJECT_DIR}/.claude/hooks/orchestrator_gate.py\"",
            "timeout": 10,
            "statusMessage": "Grille de qualification orchestrateur..."
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Skill|Agent|Task",
        "hooks": [
          {
            "type": "command",
            "command": "py \"${CLAUDE_PROJECT_DIR}/.claude/supervision/log_usage.py\"",
            "timeout": 10,
            "statusMessage": "Journal usage agents..."
          }
        ]
      }
    ]
  },
  "permissions": {
    "disableBypassPermissionsMode": "disable",
    "deny": [
      "Read(./.env)",
      "Read(./secrets/**)",
      "Read(./config/credentials.json)"
    ]
  }
}