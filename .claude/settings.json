{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash|PowerShell",
        "hooks": [{ "type": "command", "command": "py \"${CLAUDE_PROJECT_DIR}/.claude/hooks/guard_destructive_git.py\"", "timeout": 10 }]
      }
    ]
  },
  "permissions": {
    "disableBypassPermissionsMode": "disable",
    "deny": ["Read(./.env)", "Read(./secrets/**)", "Read(./config/credentials.json)"]
  }
}
